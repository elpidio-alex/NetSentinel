# =============================================================
# .env.example — Variables d'environnement NetSentinel
# Copiez ce fichier en .env et remplissez vos valeurs réelles.
# Ne committez JAMAIS le fichier .env sur Git.
# =============================================================

# ── Base de données MySQL ─────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=netsentinel_db
MYSQL_USER=root
MYSQL_PASSWORD=

# ── Paramètres de surveillance ────────────────────────────────
# Nombre de ports distincts déclenchant une alerte scan
SEUIL_SCAN_PORTS=15
# Fenêtre de temps pour la détection de scan (secondes)
FENETRE_SCAN_SECONDES=10
# Nombre de tentatives déclenchant une alerte brute-force
SEUIL_BRUTE_FORCE=10
# Fenêtre de temps pour la détection brute-force (secondes)
FENETRE_BRUTE_FORCE_SECONDES=30
# Volume de données sortantes déclenchant une alerte exfiltration (Mo)
SEUIL_EXFILTRATION_MO=50

# ── Défense ───────────────────────────────────────────────────
# Mode par défaut : passif (log uniquement) ou actif (vrai blocage pare-feu)
MODE_DEFENSE_DEFAUT=passif
# Durée des blocages temporaires (minutes)
DUREE_BLOCAGE_MINUTES=30
# Autoriser les blocages permanents : true ou false
BLOCAGE_PERMANENT_AUTORISE=false
# Confirmation utilisateur requise avant blocage actif : true ou false
CONFIRMATION_REQUISE_MODE_ACTIF=true